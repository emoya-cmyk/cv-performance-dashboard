{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxLambdaSize": "50mb",
      "includeFiles": "api/migrations/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" }
  ],
  "crons": [
    { "path": "/api/cron/tick", "schedule": "0 7 * * *" },
    { "path": "/api/cron/memory", "schedule": "30 8 * * *" }
  ]
}
