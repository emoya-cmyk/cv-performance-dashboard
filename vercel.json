{
  "version": 2,
  "buildCommand": "npm install --include=dev && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "api/migrations/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
