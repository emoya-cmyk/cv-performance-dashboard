{
  "$comment": "Baseline Claude Code project settings shared across emoya-cmyk repos. Copy to a repo's .claude/settings.json (and ship session-start.sh + hooks/block-dangerous.sh under .claude/, chmod +x). The PreToolUse gate + permissions.deny are the safety floor (harness step 9); trim the allow-list to what each repo actually uses.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/session-start.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block-dangerous.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(node --test:*)",
      "Bash(npx vite build:*)",
      "Bash(npx eslint:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(secrets/**)",
      "Write(secrets/**)"
    ]
  }
}
